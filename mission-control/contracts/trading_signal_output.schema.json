{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["status", "pair", "direction", "entry", "stop_loss", "take_profit", "confidence", "reason"],
  "properties": {
    "status": {"type": "string", "enum": ["CANDIDATE", "NO_TRADE"]},
    "pair": {"type": "string"},
    "direction": {"type": "string", "enum": ["LONG", "SHORT", "NONE"]},
    "entry": {"type": "number"},
    "stop_loss": {"type": "number"},
    "take_profit": {"type": "number"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "reason": {"type": "string"}
  }
}
